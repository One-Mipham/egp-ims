{
  "name": "omc-finance-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && eslint 'src/**/*.{ts,vue}' && vite build",
    "build:saas": "vue-tsc && eslint 'src/**/*.{ts,vue}' && VITE_BASE=/saas/ vite build",
    "build:intranet": "vue-tsc && eslint 'src/**/*.{ts,vue}' && VITE_BASE=/intranet/ vite build",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{ts,vue}'",
    "lint:fix": "eslint 'src/**/*.{ts,vue}' --fix",
    "format": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "deploy": "./deploy.sh",
    "deploy:saas": "./deploy.sh saas",
    "deploy:intranet": "./deploy.sh intranet"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "marked": "^18.0.3",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@primevue/themes": "^4.5.4",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.9.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
